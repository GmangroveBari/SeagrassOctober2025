#| label: fig-map
#| fig-cap: "Map showing October 2025 sampling area and proximity to AMIkids marina."
#| fig-align: "center"
df <- data.frame(
lng = c(-82.596, -82.614),
lat = c(27.854, 27.87),
site = c("Oct. 2025 Sampling Area", "AMIkids Marina")
)
# Create the map using the data frame
df %>%
leaflet() %>%
addTiles() %>%
addMarkers(
lng = ~lng,
lat = ~lat,
popup = ~site, # Use the 'site' column for popups
),
df %>%
leaflet()
library(dplyr)
df %>%
leaflet() %>%
addTiles() %>%
addMarkers(
lng = ~lng,
lat = ~lat,
popup = ~site, # Use the 'site' column for popups
) %>%
setView(lng = -82.605, lat = 27.866, zoom = 14)
# Generate a markdown table
knitr::kable(mean_sed, format = "html", align = "cc",)
sed <- read_csv("https://raw.githubusercontent.com/GmangroveBari/SeagrassOctober2025/refs/heads/main/202510-SeagrassDataAMIkidsConcatated.csv", col_select = c(Day, SedimentType))
knitr::kable(head(summary_table), digits = 1,  align = "lccccc",)
summary_table <- Table2a %>%
group_by(Species) %>%
summarise(
n = n(), # Number of observations
Appearance = mean(Appearance, na.rm = TRUE),
EpiphtyDensity = mean(EpiphyteDensity, na.rm = TRUE),
ShootDensity = mean(ShtDen, na.rm = TRUE),
BladeLength = mean(AvgBld, na.rm = TRUE)
)
# rename columns 4-6
colnames(summary_table)[4] <- "Epiphyte Density"
colnames(summary_table)[5] <- "Shoot Density"
colnames(summary_table)[6] <- "Blade Length"
# Generate a markdown table
knitr::kable(head(summary_table), digits = 1,  align = "lccccc",)
#| label: tbl-means
#| tbl-cap: "Overall averages for several different seagrass metrics assessed from Oct. 20-25, 2025."
Table2a <- read.csv("https://raw.githubusercontent.com/GmangroveBari/SeagrassOctober2025/refs/heads/main/202510-SeagrassDataAMIkidsConcatated.csv")
# Create a custom summary table
summary_table <- Table2a %>%
group_by(Species) %>%
summarise(
n = n(), # Number of observations
Appearance = mean(Appearance, na.rm = TRUE),
EpiphtyDensity = mean(EpiphyteDensity, na.rm = TRUE),
ShootDensity = mean(ShtDen, na.rm = TRUE),
BladeLength = mean(AvgBld, na.rm = TRUE)
)
# rename columns 4-6
colnames(summary_table)[4] <- "Epiphyte Density"
colnames(summary_table)[5] <- "Shoots/m2"
colnames(summary_table)[6] <- "Blade Length (cm)"
# Remove empty row
summary_table <- summary_table[-c(4)]
# Generate a markdown table
knitr::kable(head(summary_table), digits = 1,  align = "lccccc")
